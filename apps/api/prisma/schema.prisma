// ERP — full schema. Generated by module. PostgreSQL.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH & RBAC
// ============================================================
enum Role {
  ADMIN
  MANAGER
  HR
  ACCOUNTANT
  EMPLOYEE
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  role         Role      @default(EMPLOYEE)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  // Optional link to an HR employee record
  employee     Employee?

  auditLogs    AuditLog[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([role])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String   // e.g. "invoice.create"
  entity     String   // e.g. "Invoice"
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================================
// FINANCE — multi-currency, double-entry general ledger
// ============================================================
model Currency {
  code         String         @id // ISO 4217, e.g. "USD"
  name         String
  symbol       String
  isBase       Boolean        @default(false)
  ratesFrom    ExchangeRate[] @relation("FromCurrency")
  ratesTo      ExchangeRate[] @relation("ToCurrency")
  accounts     Account[]
  invoices     Invoice[]
  quotes       Quote[]
  salesOrders  SalesOrder[]
}

model ExchangeRate {
  id            String   @id @default(cuid())
  fromCode      String
  toCode        String
  rate          Decimal  @db.Decimal(18, 8)
  asOf          DateTime
  fromCurrency  Currency @relation("FromCurrency", fields: [fromCode], references: [code])
  toCurrency    Currency @relation("ToCurrency", fields: [toCode], references: [code])

  @@unique([fromCode, toCode, asOf])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model Account {
  id           String        @id @default(cuid())
  code         String        @unique // e.g. "1000"
  name         String
  type         AccountType
  // Self-referential tree for sub-accounts
  parentId     String?
  parent       Account?      @relation("AccountTree", fields: [parentId], references: [id])
  children     Account[]     @relation("AccountTree")
  currencyCode String?
  currency     Currency?     @relation(fields: [currencyCode], references: [code])
  isActive     Boolean       @default(true)
  description  String?

  journalLines JournalLine[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([type])
}

enum JournalSource {
  MANUAL
  INVOICE
  PAYMENT
  PAYROLL
  DEPRECIATION
  EXPENSE
}

model JournalEntry {
  id          String        @id @default(cuid())
  reference   String        @unique @default(cuid())
  date        DateTime
  memo        String?
  source      JournalSource @default(MANUAL)
  // Soft link back to originating document (invoiceId, payslipId, ...)
  sourceId    String?
  isPosted    Boolean       @default(true)
  lines       JournalLine[]
  createdById String?
  createdAt   DateTime      @default(now())

  @@index([date])
  @@index([source, sourceId])
}

model JournalLine {
  id        String       @id @default(cuid())
  entryId   String
  entry     JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  accountId String
  account   Account      @relation(fields: [accountId], references: [id])
  debit     Decimal      @default(0) @db.Decimal(18, 2)
  credit    Decimal      @default(0) @db.Decimal(18, 2)
  memo      String?

  @@index([accountId])
  @@index([entryId])
}

// ============================================================
// SALES & CRM
// ============================================================
enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

model Customer {
  id           String        @id @default(cuid())
  name         String
  email        String?
  phone        String?
  company      String?
  taxId        String?
  billingAddr  String?
  shippingAddr String?
  notes        String?
  isActive     Boolean       @default(true)

  leads        Lead[]
  quotes       Quote[]
  salesOrders  SalesOrder[]
  invoices     Invoice[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([name])
}

model Lead {
  id          String     @id @default(cuid())
  customerId  String?
  customer    Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  contactName String
  email       String?
  phone       String?
  source      String?    // e.g. "Website", "Referral"
  status      LeadStatus @default(NEW)
  estValue    Decimal?   @db.Decimal(18, 2)
  ownerId     String?    // userId of sales rep
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status])
}

model Product {
  id          String  @id @default(cuid())
  sku         String  @unique
  name        String
  description String?
  unitPrice   Decimal @db.Decimal(18, 2)
  taxRate     Decimal @default(0) @db.Decimal(5, 2) // percent
  isActive    Boolean @default(true)

  quoteItems  QuoteItem[]
  orderItems  SalesOrderItem[]
  invoiceItems InvoiceItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum DocStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  CANCELLED
}

model Quote {
  id          String      @id @default(cuid())
  number      String      @unique
  customerId  String
  customer    Customer    @relation(fields: [customerId], references: [id])
  status      DocStatus   @default(DRAFT)
  issueDate   DateTime    @default(now())
  validUntil  DateTime?
  currencyCode String     @default("USD")
  currency    Currency    @relation(fields: [currencyCode], references: [code])
  notes       String?
  subtotal    Decimal     @default(0) @db.Decimal(18, 2)
  taxTotal    Decimal     @default(0) @db.Decimal(18, 2)
  total       Decimal     @default(0) @db.Decimal(18, 2)
  items       QuoteItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  description String
  quantity    Decimal  @db.Decimal(18, 2)
  unitPrice   Decimal  @db.Decimal(18, 2)
  taxRate     Decimal  @default(0) @db.Decimal(5, 2)
  lineTotal   Decimal  @db.Decimal(18, 2)
}

enum OrderStatus {
  PENDING
  CONFIRMED
  FULFILLED
  CANCELLED
}

model SalesOrder {
  id          String           @id @default(cuid())
  number      String           @unique
  customerId  String
  customer    Customer         @relation(fields: [customerId], references: [id])
  status      OrderStatus      @default(PENDING)
  orderDate   DateTime         @default(now())
  currencyCode String          @default("USD")
  currency    Currency         @relation(fields: [currencyCode], references: [code])
  notes       String?
  subtotal    Decimal          @default(0) @db.Decimal(18, 2)
  taxTotal    Decimal          @default(0) @db.Decimal(18, 2)
  total       Decimal          @default(0) @db.Decimal(18, 2)
  items       SalesOrderItem[]
  invoices    Invoice[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model SalesOrderItem {
  id          String     @id @default(cuid())
  orderId     String
  order       SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?   @relation(fields: [productId], references: [id])
  description String
  quantity    Decimal    @db.Decimal(18, 2)
  unitPrice   Decimal    @db.Decimal(18, 2)
  taxRate     Decimal    @default(0) @db.Decimal(5, 2)
  lineTotal   Decimal    @db.Decimal(18, 2)
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id           String        @id @default(cuid())
  number       String        @unique
  customerId   String
  customer     Customer      @relation(fields: [customerId], references: [id])
  salesOrderId String?
  salesOrder   SalesOrder?   @relation(fields: [salesOrderId], references: [id])
  status       InvoiceStatus @default(DRAFT)
  issueDate    DateTime      @default(now())
  dueDate      DateTime?
  currencyCode String        @default("USD")
  currency     Currency      @relation(fields: [currencyCode], references: [code])
  notes        String?
  subtotal     Decimal       @default(0) @db.Decimal(18, 2)
  taxTotal     Decimal       @default(0) @db.Decimal(18, 2)
  total        Decimal       @default(0) @db.Decimal(18, 2)
  amountPaid   Decimal       @default(0) @db.Decimal(18, 2)
  items        InvoiceItem[]
  payments     Payment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
  @@index([dueDate])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  description String
  quantity    Decimal  @db.Decimal(18, 2)
  unitPrice   Decimal  @db.Decimal(18, 2)
  taxRate     Decimal  @default(0) @db.Decimal(5, 2)
  lineTotal   Decimal  @db.Decimal(18, 2)
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  CHECK
  OTHER
}

model Payment {
  id         String        @id @default(cuid())
  invoiceId  String
  invoice    Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount     Decimal       @db.Decimal(18, 2)
  method     PaymentMethod @default(BANK_TRANSFER)
  reference  String?
  paidAt     DateTime      @default(now())
  createdAt  DateTime      @default(now())

  @@index([paidAt])
}

// ============================================================
// HR & PAYROLL
// ============================================================
model Department {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  employees   Employee[]
  assignments AssetAssignment[]
}

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
}

model Employee {
  id            String             @id @default(cuid())
  employeeNo    String             @unique
  userId        String?            @unique
  user          User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  firstName     String
  lastName      String
  email         String?
  phone         String?
  dateOfBirth   DateTime?
  address       String?
  jobTitle      String?
  departmentId  String?
  department    Department?        @relation(fields: [departmentId], references: [id])
  hireDate      DateTime?
  status        EmploymentStatus   @default(ACTIVE)
  baseSalary    Decimal            @default(0) @db.Decimal(18, 2)

  contracts     EmploymentContract[]
  documents     EmployeeDocument[]
  attendance    Attendance[]
  leaveRequests LeaveRequest[]
  payslips      Payslip[]
  reviews       PerformanceReview[]
  assetAssignments AssetAssignment[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([departmentId])
}

model EmploymentContract {
  id          String    @id @default(cuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type        String    // FULL_TIME, PART_TIME, CONTRACT
  startDate   DateTime
  endDate     DateTime?
  salary      Decimal   @db.Decimal(18, 2)
  fileUrl     String?
  createdAt   DateTime  @default(now())
}

model EmployeeDocument {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title       String
  category    String?  // ID, Certificate, Contract...
  fileUrl     String
  uploadedAt  DateTime @default(now())
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  REMOTE
}

model Attendance {
  id         String           @id @default(cuid())
  employeeId String
  employee   Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime         @db.Date
  checkIn    DateTime?
  checkOut   DateTime?
  status     AttendanceStatus @default(PRESENT)
  hours      Decimal?         @db.Decimal(5, 2)

  @@unique([employeeId, date])
}

enum LeaveType {
  ANNUAL
  SICK
  UNPAID
  MATERNITY
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model LeaveRequest {
  id          String      @id @default(cuid())
  employeeId  String
  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type        LeaveType   @default(ANNUAL)
  startDate   DateTime
  endDate     DateTime
  days        Decimal     @db.Decimal(5, 2)
  reason      String?
  status      LeaveStatus @default(PENDING)
  reviewedBy  String?
  createdAt   DateTime    @default(now())

  @@index([status])
}

enum PayslipStatus {
  DRAFT
  APPROVED
  PAID
}

model Payslip {
  id          String        @id @default(cuid())
  employeeId  String
  employee    Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  periodStart DateTime
  periodEnd   DateTime
  grossPay    Decimal       @default(0) @db.Decimal(18, 2)
  totalDeductions Decimal   @default(0) @db.Decimal(18, 2)
  taxAmount   Decimal       @default(0) @db.Decimal(18, 2)
  netPay      Decimal       @default(0) @db.Decimal(18, 2)
  status      PayslipStatus @default(DRAFT)
  lines       PayslipLine[]
  createdAt   DateTime      @default(now())

  @@unique([employeeId, periodStart, periodEnd])
}

enum PayslipLineType {
  EARNING
  DEDUCTION
  TAX
}

model PayslipLine {
  id        String          @id @default(cuid())
  payslipId String
  payslip   Payslip         @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  type      PayslipLineType
  label     String
  amount    Decimal         @db.Decimal(18, 2)
}

model PerformanceReview {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reviewerId  String?
  periodLabel String   // e.g. "2026 H1"
  rating      Int      // 1-5
  strengths   String?
  improvements String?
  goals       String?
  createdAt   DateTime @default(now())
}

// ============================================================
// ASSET MANAGEMENT
// ============================================================
enum AssetStatus {
  IN_USE
  IN_STORAGE
  UNDER_MAINTENANCE
  DISPOSED
}

enum DepreciationMethod {
  STRAIGHT_LINE
  DECLINING_BALANCE
  NONE
}

model Asset {
  id              String             @id @default(cuid())
  tag             String             @unique
  name            String
  category        String?
  serialNumber    String?
  purchaseDate    DateTime?
  purchaseCost    Decimal            @default(0) @db.Decimal(18, 2)
  salvageValue    Decimal            @default(0) @db.Decimal(18, 2)
  usefulLifeMonths Int?
  depreciationMethod DepreciationMethod @default(STRAIGHT_LINE)
  status          AssetStatus        @default(IN_STORAGE)
  location        String?
  notes           String?

  depreciation    DepreciationEntry[]
  maintenance     MaintenanceRecord[]
  assignments     AssetAssignment[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
}

model DepreciationEntry {
  id            String   @id @default(cuid())
  assetId       String
  asset         Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  periodDate    DateTime
  amount        Decimal  @db.Decimal(18, 2)
  bookValueAfter Decimal @db.Decimal(18, 2)
  createdAt     DateTime @default(now())

  @@unique([assetId, periodDate])
}

model MaintenanceRecord {
  id          String   @id @default(cuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  date        DateTime
  description String
  cost        Decimal  @default(0) @db.Decimal(18, 2)
  vendor      String?
  createdAt   DateTime @default(now())
}

model AssetAssignment {
  id           String      @id @default(cuid())
  assetId      String
  asset        Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  employeeId   String?
  employee     Employee?   @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  assignedAt   DateTime    @default(now())
  returnedAt   DateTime?
  notes        String?

  @@index([assetId])
}
