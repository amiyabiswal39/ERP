# Production build config (loaded by Vite during `npm run build`).
# Empty value => the app calls the API at a RELATIVE "/api", which nginx
# reverse-proxies to the Node API on the same host. If you ever host the API
# on a different domain, set the full origin here, e.g.:
#   VITE_API_URL=https://api.yourdomain.com
VITE_API_URL=
