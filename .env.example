# Copy to .env at repo root (used by docker-compose) and apps/api/.env (used by Prisma + API)
DATABASE_URL="postgresql://erp:erp_password@localhost:5432/erp?schema=public"

# Auth — generate strong secrets in production (e.g. `openssl rand -hex 32`)
JWT_ACCESS_SECRET="dev_access_secret_change_me"
JWT_REFRESH_SECRET="dev_refresh_secret_change_me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# API
PORT="4000"
NODE_ENV="development"
CORS_ORIGIN="http://localhost:5173"
LOG_LEVEL="info"

# Web (Vite)
VITE_API_URL="http://localhost:4000"
