# Production API environment — copy to apps/api/.env on the server and fill in.
# Generate strong secrets with: openssl rand -hex 32

DATABASE_URL="postgresql://erp:CHANGE_ME_DB_PASSWORD@localhost:5432/erp?schema=public"

JWT_ACCESS_SECRET="CHANGE_ME_with_openssl_rand_hex_32"
JWT_REFRESH_SECRET="CHANGE_ME_with_a_different_openssl_rand_hex_32"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

PORT="4000"
NODE_ENV="production"
LOG_LEVEL="info"

# Same-origin behind nginx, so set this to your public URL (used by CORS).
CORS_ORIGIN="http://YOUR_EC2_PUBLIC_DNS"
